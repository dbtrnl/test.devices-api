{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Database",
            "type": "shell",
            "command": "make",
            "args": [
                "init-db"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Compile",
            "type": "shell",
            "command": "go",
            "dependsOn": [
                "Start Database"
            ],
            "args": [
                "build",
                "-o",
                "bin/api",
                "./cmd/api"
            ]
        }
    ]
}